{"ast":null,"code":"import{createContext,useContext,useEffect,useState}from\"react\";import{jsx as _jsx}from\"react/jsx-runtime\";const ContentContext=/*#__PURE__*/createContext();export default function ContentProvider(_ref){let{children}=_ref;const[data,setData]=useState(()=>{const storedData=localStorage.getItem('content');return storedData?JSON.parse(storedData):[];});const addContent=content=>{setData(prev=>[...prev,{...content,comments:[]}]);};const editContent=updatedContent=>{setData(prev=>prev.map(item=>item.id===updatedContent.id?{...updatedContent,comments:item.comments}:item));};const deleteContent=id=>{setData(prev=>prev.filter(item=>item.id!==id));};const addComment=(contentId,comment)=>{setData(prev=>prev.map(item=>item.id===contentId?{...item,comments:[...(item.comments||[]),comment]}:item));};useEffect(()=>{localStorage.setItem('content',JSON.stringify(data));},[data]);return/*#__PURE__*/_jsx(ContentContext.Provider,{value:{data,addContent,editContent,deleteContent,addComment},children:children});}export const useContent=()=>useContext(ContentContext);","map":{"version":3,"names":["createContext","useContext","useEffect","useState","jsx","_jsx","ContentContext","ContentProvider","_ref","children","data","setData","storedData","localStorage","getItem","JSON","parse","addContent","content","prev","comments","editContent","updatedContent","map","item","id","deleteContent","filter","addComment","contentId","comment","setItem","stringify","Provider","value","useContent"],"sources":["C:/Users/ankit/Downloads/cms-react-main (1)/cms-react-main/src/context/ContentContext.jsx"],"sourcesContent":["import { createContext, useContext, useEffect, useState } from \"react\";\n\nconst ContentContext = createContext();\n\nexport default function ContentProvider({children}) {\n    const [data, setData] = useState(() => {\n        const storedData = localStorage.getItem('content');\n        return storedData ? JSON.parse(storedData) : [];\n    });\n\n    const addContent = (content) => {\n        setData((prev) => [...prev, {...content, comments: []}])\n    }\n\n\n    const editContent = (updatedContent) => {\n        setData((prev) => prev.map((item) => \n        item.id === updatedContent.id ? {...updatedContent, comments: item.comments} : item\n        ))\n    }\n\n\n    const deleteContent = (id) => {\n        setData((prev) => prev.filter((item) => item.id !== id))\n    }\n\n    const addComment = (contentId, comment) => {\n        setData((prev) => prev.map(\n            (item) => item.id === contentId ? {...item, comments: [...(item.comments || []), comment]} : item))\n    }\n\n    useEffect(() => {\n        localStorage.setItem('content', JSON.stringify(data))\n    }, [data])\n\n    return (\n        <ContentContext.Provider value={{data, addContent, editContent, deleteContent, addComment}}>\n            {children}\n        </ContentContext.Provider>\n    )\n}\n\nexport const useContent = () => useContext(ContentContext);\n\n"],"mappings":"AAAA,OAASA,aAAa,CAAEC,UAAU,CAAEC,SAAS,CAAEC,QAAQ,KAAQ,OAAO,CAAC,OAAAC,GAAA,IAAAC,IAAA,yBAEvE,KAAM,CAAAC,cAAc,cAAGN,aAAa,CAAC,CAAC,CAEtC,cAAe,SAAS,CAAAO,eAAeA,CAAAC,IAAA,CAAa,IAAZ,CAACC,QAAQ,CAAC,CAAAD,IAAA,CAC9C,KAAM,CAACE,IAAI,CAAEC,OAAO,CAAC,CAAGR,QAAQ,CAAC,IAAM,CACnC,KAAM,CAAAS,UAAU,CAAGC,YAAY,CAACC,OAAO,CAAC,SAAS,CAAC,CAClD,MAAO,CAAAF,UAAU,CAAGG,IAAI,CAACC,KAAK,CAACJ,UAAU,CAAC,CAAG,EAAE,CACnD,CAAC,CAAC,CAEF,KAAM,CAAAK,UAAU,CAAIC,OAAO,EAAK,CAC5BP,OAAO,CAAEQ,IAAI,EAAK,CAAC,GAAGA,IAAI,CAAE,CAAC,GAAGD,OAAO,CAAEE,QAAQ,CAAE,EAAE,CAAC,CAAC,CAAC,CAC5D,CAAC,CAGD,KAAM,CAAAC,WAAW,CAAIC,cAAc,EAAK,CACpCX,OAAO,CAAEQ,IAAI,EAAKA,IAAI,CAACI,GAAG,CAAEC,IAAI,EAChCA,IAAI,CAACC,EAAE,GAAKH,cAAc,CAACG,EAAE,CAAG,CAAC,GAAGH,cAAc,CAAEF,QAAQ,CAAEI,IAAI,CAACJ,QAAQ,CAAC,CAAGI,IAC/E,CAAC,CAAC,CACN,CAAC,CAGD,KAAM,CAAAE,aAAa,CAAID,EAAE,EAAK,CAC1Bd,OAAO,CAAEQ,IAAI,EAAKA,IAAI,CAACQ,MAAM,CAAEH,IAAI,EAAKA,IAAI,CAACC,EAAE,GAAKA,EAAE,CAAC,CAAC,CAC5D,CAAC,CAED,KAAM,CAAAG,UAAU,CAAGA,CAACC,SAAS,CAAEC,OAAO,GAAK,CACvCnB,OAAO